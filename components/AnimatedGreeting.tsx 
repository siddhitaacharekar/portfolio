"use client";
import { useEffect, useState } from "react";

// Only the greeting word cycles; "I’m Siddhita 👋" stays static beside it.
const GREETINGS = ["Hello", "Hola", "Bonjour", "Hallo", "Ciao", "नमस्ते"];
// Accelerating rhythm, with a longer hold on the last language before it settles
const DURATIONS = [600, 550, 520, 500, 480, 750];

export default function AnimatedGreeting() {
  const [index, setIndex] = useState(0);
  const [done, setDone] = useState(false);

  // Skip for reduced-motion users or if already seen this session
  useEffect(() => {
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced || sessionStorage.getItem("greetPlayed")) setDone(true);
  }, []);

  useEffect(() => {
    if (done) return;
    if (index < GREETINGS.length - 1) {
      const t = setTimeout(() => setIndex((i) => i + 1), DURATIONS[index]);
      return () => clearTimeout(t);
    }
    const t = setTimeout(() => {
      setDone(true);
      sessionStorage.setItem("greetPlayed", "1");
    }, DURATIONS[GREETINGS.length - 1]);
    return () => clearTimeout(t);
  }, [index, done]);

  // Settles back to "Hi"
  if (done) {
    return (
      <span className="greet-word" key="final">
        Hi
      </span>
    );
  }

  return (
    <span className="greet-word" key={index}>
      {GREETINGS[index]}
    </span>
  );
}